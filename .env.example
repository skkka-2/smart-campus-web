# 复制本文件为 .env / .env.development / .env.production 后按需修改
#
# VITE_BASE_API   axios 的 baseURL。空字符串表示走 vite proxy(dev 推荐)
# VITE_WS_URL     聊天室 WebSocket 地址(前端直连,不走 proxy)
# VITE_PROXY_TARGET  dev 模式下 vite server.proxy 的目标(仅 dev 用)

VITE_BASE_API=
VITE_WS_URL=ws://127.0.0.1:3007
VITE_PROXY_TARGET=http://127.0.0.1:3007
